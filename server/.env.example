# Copy to server/.env and fill in your paths.
# gamdl venv site-packages (provides gamdl + pywidevine):
GAMDL_SITE=/path/to/.local/pipx/venvs/gamdl/lib/pythonX.Y/site-packages
# Python interpreter inside that venv:
PYTHON_BIN=/path/to/.local/pipx/venvs/gamdl/bin/python3
# Binaries (leave as bare names to resolve from PATH):
MP4DECRYPT_BIN=mp4decrypt
FFMPEG_BIN=ffmpeg
